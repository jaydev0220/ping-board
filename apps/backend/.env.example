# Server
NODE_ENV=
HOST=
PORT=

# Pinger
PING_TIMEOUT_MS=

# Database
SQLITE_PATH=

# CORS
# Comma-separated list (full URL, no trailing slash)
CORS_ALLOWED_ORIGINS=

# Relay
# Shared secret required in X-Relay-Secret header from frontend relay
RELAY_SECRET=

# Auth
# Minimum 32 characters
JWT_SECRET=
# Token lifetimes
ACCESS_TOKEN_TTL=
REFRESH_TOKEN_TTL=
