{
	"name": "@apps/backend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "tsx watch --env-file=.env.development src/server.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node build/server.js",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"lint": "eslint .",
		"format": "prettier --write .",
		"migrate:make": "knex migrate:make",
		"migrate:latest": "knex migrate:latest",
		"migrate:rollback": "knex migrate:rollback",
		"test-pinger": "node --experimental-transform-types scripts/test-pinger.ts",
		"test-auth": "node --experimental-transform-types scripts/test-auth.ts",
		"test-services-quota": "node --experimental-transform-types scripts/test-services-quota.ts",
		"test-relay-security": "node --experimental-transform-types scripts/test-relay-security.ts"
	},
	"dependencies": {
		"argon2": "catalog:",
		"better-sqlite3": "catalog:",
		"cookie-parser": "catalog:",
		"jose": "catalog:",
		"cors": "catalog:",
		"express": "catalog:",
		"helmet": "catalog:",
		"knex": "catalog:",
		"node-cron": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@eslint/compat": "catalog:",
		"@eslint/js": "catalog:",
		"@types/better-sqlite3": "catalog:",
		"@types/cookie-parser": "catalog:",
		"@types/cors": "catalog:",
		"@types/express": "catalog:",
		"@types/node": "catalog:",
		"eslint": "catalog:",
		"globals": "catalog:",
		"prettier": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"typescript-eslint": "catalog:"
	}
}
