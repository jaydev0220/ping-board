{
	"name": "@apps/backend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "node --watch --experimental-transform-types src/server.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node build/server.js",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"lint": "eslint src",
		"format": "prettier --write .",
		"migrate:make": "knex migrate:make",
		"migrate:latest": "knex migrate:latest",
		"migrate:rollback": "knex migrate:rollback"
	},
	"dependencies": {
		"better-sqlite3": "catalog:",
		"cors": "catalog:",
		"express": "catalog:",
		"helmet": "catalog:",
		"knex": "catalog:",
		"node-cron": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@eslint/js": "catalog:",
		"@types/better-sqlite3": "catalog:",
		"@types/cors": "catalog:",
		"@types/express": "catalog:",
		"@types/node": "catalog:",
		"eslint": "catalog:",
		"globals": "catalog:",
		"prettier": "catalog:",
		"typescript": "catalog:",
		"typescript-eslint": "catalog:"
	}
}
